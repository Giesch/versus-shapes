{
  "name": "versus-shapes",
  "private": true,
  "version": "1.0.0",
  "description": "a jazzy 3D Super Hexagon clone",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"vite --port 5173 --strictPort\" \"rcade dev http://localhost:5173\"",
    "build": "vite build",
    "format": "prettier --write .",
    "download-audio": "./scripts/download-audio.sh",
    "beats-json": "./scripts/extract_beats.py ./public",
    "typecheck": "tsc --build --noEmit",
    "typecheck:watch": "tsc --build --noEmit --watch"
  },
  "devDependencies": {
    "@webgpu/types": "^0.1.69",
    "concurrently": "^9.0.0",
    "rcade": "^0.0.42",
    "typescript": "~5.9.3",
    "unplugin-typegpu": "^0.11.0",
    "vite": "^7.2.4"
  },
  "dependencies": {
    "@rcade/plugin-input-classic": "^0.2.1",
    "typegpu": "^0.11.2",
    "wgpu-matrix": "^3.4.2"
  }
}
